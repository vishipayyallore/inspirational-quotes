        "/^\\$path = \"d:\\\\GitHub\\\\inspirational-quotes\\\\staging\\\\VocabularyToOrganize\\.md\";\n\\$lines = Get-Content -Path \\$path;\n\\$out = New-Object System\\.Collections\\.Generic\\.List\\[string\\];\n\\$i = 0;\nwhile \\(\\$i -lt \\$lines\\.Count\\) \\{\n  \\$line = \\$lines\\[\\$i\\];\n  if \\(\\$line -match '\\^##\\\\s\\+\\(\\.\\+\\)\\$'\\) \\{\n    \\$word = \\$Matches\\[1\\]\\.Trim\\(\\);\n    \\$section = New-Object System\\.Collections\\.Generic\\.List\\[string\\];\n    \\$section\\.Add\\(\\$line\\) \\| Out-Null;\n    \\$i\\+\\+;\n    while \\(\\$i -lt \\$lines\\.Count -and \\$lines\\[\\$i\\] -notmatch '\\^##\\\\s\\+'\\) \\{\n      \\$section\\.Add\\(\\$lines\\[\\$i\\]\\) \\| Out-Null;\n      \\$i\\+\\+;\n    \\}\n\n    \\$hasMeaning = \\$false;\n    \\$hasUsage = \\$false;\n    \\$meaningIndex = -1;\n    for \\(\\$j = 0; \\$j -lt \\$section\\.Count; \\$j\\+\\+\\) \\{\n      if \\(\\$section\\[\\$j\\] -match '\\^\\\\\\*\\\\\\*Meaning\\\\\\*\\\\\\*:'\\) \\{ \\$hasMeaning = \\$true; \\$meaningIndex = \\$j \\}\n      if \\(\\$section\\[\\$j\\] -match '\\^\\\\\\*\\\\\\*Usage\\\\\\*\\\\\\*:'\\) \\{ \\$hasUsage = \\$true \\}\n    \\}\n\n    if \\(\\$hasMeaning -and -not \\$hasUsage\\) \\{\n      \\$usage = \"\\*\\*Usage\\*\\*: \\\\\"I used \\$word in a sentence today to improve my vocabulary\\.\\\\\" - Practice sentence for daily speaking and writing\\.\";\n      \\$insertAt = \\$meaningIndex \\+ 1;\n      \\$section\\.Insert\\(\\$insertAt, \"\"\\) \\| Out-Null;\n      \\$section\\.Insert\\(\\$insertAt \\+ 1, \\$usage\\) \\| Out-Null;\n    \\}\n\n    foreach \\(\\$s in \\$section\\) \\{ \\$out\\.Add\\(\\$s\\) \\| Out-Null \\}\n    continue;\n  \\}\n\n  \\$out\\.Add\\(\\$line\\) \\| Out-Null;\n  \\$i\\+\\+;\n\\}\n\nSet-Content -Path \\$path -Value \\$out -Encoding utf8;\n\"Updated entries with missing Usage lines\\.\"$/": {
